    },
    {
      "id": "ml_primary",
      "language": "ml",
      "tier": "primary",
      "modelPath": "assets/tts/models/ml/primary/model.onnx",
      "tokensPath": "assets/tts/models/ml/primary/tokens.txt",
      "dataDir": "assets/tts/models/espeak-ng-data",
      "description": "Malayalam smooth primary"
    },
    {
      "id": "ml_backup",
      "language": "ml",
      "tier": "backup",
      "modelPath": "assets/tts/models/ml/backup/model.onnx",
      "tokensPath": "assets/tts/models/ml/backup/tokens.txt",
      "dataDir": "assets/tts/models/espeak-ng-data",
