{
  "version": 1,
  "notes": "Desktop Sherpa-ONNX model manifest for Linux/Windows. Place models under assets/tts/models and binaries under assets/tts/bin or install sherpa in PATH.",
  "commands": {
    "linux": [
      "assets/tts/bin/linux-x64/sherpa-onnx-offline-tts-play",
      "assets/tts/bin/linux-x64/sherpa-onnx-offline-tts-play-alsa",
      "assets/tts/bin/linux-x64/sherpa-onnx-offline-tts",
      "sherpa-onnx-offline-tts-play",
      "sherpa-onnx-offline-tts-play-alsa",
      "sherpa-onnx-offline-tts",
      "sherpa-onnx-tts-play"
    ],
    "windows": [
      "assets/tts/bin/windows-x64/sherpa-onnx-offline-tts-play.exe",
      "sherpa-onnx-offline-tts-play.exe",
      "sherpa-onnx-tts-play.exe"
    ]
  },
  "models": [
    {
      "id": "en_primary",
      "language": "en",
