# SolasFlow Release Keystore Configuration
# ==========================================
# Copy this file to keystore.properties and fill in your values.
# NEVER commit keystore.properties or the .jks file to version control.
#
# 1. Generate a keystore:
#    keytool -genkey -v -keystore upload-keystore.jks -alias upload -keyalg RSA -keysize 2048 -validity 10000
#
# 2. For CI, encode your JKS as base64 and store as GitHub secret KEYSTORE_BASE64:
#    base64 -w 0 upload-keystore.jks | pbcopy   # macOS
#    base64 -w 0 upload-keystore.jks             # Linux (pipe to clipboard)
#
# 3. Add these GitHub secrets:
#    KEYSTORE_BASE64  -> base64-encoded .jks file
#    KEY_ALIAS        -> upload
#    KEY_PASSWORD     -> abc123
#    STORE_PASSWORD   -> abc123

storeFile=../../upload-keystore.jks
storePassword=YOUR_STORE_PASSWORD
keyAlias=YOUR_KEY_ALIAS
keyPassword=YOUR_KEY_PASSWORD
