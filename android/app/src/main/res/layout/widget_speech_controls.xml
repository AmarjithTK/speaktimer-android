<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_bg"
    android:padding="16dp">

    <!-- Header: app label + tonal "Open" action -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="14dp">

        <!-- M3 Label Small — onSurfaceVariant, wide letter-spacing -->
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Lifer · Speech"
            android:textColor="#FFCAC4D0"
            android:textSize="11sp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.1" />

        <!-- M3 Tonal Button (SecondaryContainer) -->
        <Button
            android:id="@+id/btn_open_app"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="Open"
            android:textAllCaps="false"
            android:textSize="12sp"
            android:fontFamily="sans-serif-medium"
            android:textColor="#FFE8DEF8"
            android:background="@drawable/widget_button_tonal_bg"
            android:paddingStart="16dp"
            android:paddingEnd="16dp" />
    </LinearLayout>

    <!-- Row 1: Clock Speech + Timer Speech -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:layout_marginBottom="6dp">

        <Button
            android:id="@+id/btn_clock_speech"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="Clock: OFF"
            android:textAllCaps="false"
            android:textSize="12sp"
            android:fontFamily="sans-serif-medium"
            android:textColor="#FFE6E1E5"
            android:background="@drawable/widget_button_bg" />

        <Button
            android:id="@+id/btn_timer_speech"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Timer: OFF"
            android:textAllCaps="false"
            android:textSize="12sp"
            android:fontFamily="sans-serif-medium"
            android:textColor="#FFE6E1E5"
            android:background="@drawable/widget_button_bg" />
    </LinearLayout>

    <!-- Row 2: Stopwatch Speech + Goals Speech -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btn_stopwatch_speech"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="Stopwatch: OFF"
            android:textAllCaps="false"
            android:textSize="12sp"
            android:fontFamily="sans-serif-medium"
            android:textColor="#FFE6E1E5"
            android:background="@drawable/widget_button_bg" />

        <Button
            android:id="@+id/btn_goals_speech"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Goals: OFF"
            android:textAllCaps="false"
            android:textSize="12sp"
            android:fontFamily="sans-serif-medium"
            android:textColor="#FFE6E1E5"
            android:background="@drawable/widget_button_bg" />
    </LinearLayout>

    <!-- Row 3: Fullscreen quick actions -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:layout_marginTop="6dp">

        <Button
            android:id="@+id/btn_fs_clock"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="FS Clock"
            android:textAllCaps="false"
            android:textSize="12sp"
            android:fontFamily="sans-serif-medium"
            android:textColor="#FFE6E1E5"
            android:background="@drawable/widget_button_bg" />

        <Button
            android:id="@+id/btn_fs_timer"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="Start+FS Timer"
            android:textAllCaps="false"
            android:textSize="12sp"
            android:fontFamily="sans-serif-medium"
            android:textColor="#FFE6E1E5"
            android:background="@drawable/widget_button_bg" />

        <Button
            android:id="@+id/btn_fs_stopwatch"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Start+FS SW"
            android:textAllCaps="false"
            android:textSize="12sp"
            android:fontFamily="sans-serif-medium"
            android:textColor="#FFE6E1E5"
            android:background="@drawable/widget_button_bg" />
    </LinearLayout>

</LinearLayout>

