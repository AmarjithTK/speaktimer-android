<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/speech_widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="10dp"
    android:background="@android:drawable/dialog_holo_light_frame"
    android:gravity="center_horizontal">

    <TextView
        android:id="@+id/speech_widget_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Speech: ON"
        android:textStyle="bold"
        android:textSize="14sp"
        android:textColor="#000000" />

    <TextView
        android:id="@+id/speech_widget_timer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Timer: 00:00"
        android:textSize="12sp"
        android:textColor="#444444" />

    <TextView
        android:id="@+id/speech_widget_night"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="Night: Off"
        android:textSize="11sp"
        android:textColor="#444444" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal"
        android:gravity="center">

        <Button
            android:id="@+id/speech_widget_toggle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:minHeight="40dp"
            android:text="Speech"
            android:textStyle="bold"
            android:textSize="12sp"
            android:textColor="#1a73e8" />

        <Button
            android:id="@+id/speech_widget_timer_toggle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:minHeight="40dp"
            android:text="Start/Stop"
            android:textStyle="bold"
            android:textSize="12sp"
            android:textColor="#1a73e8" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:orientation="horizontal"
        android:gravity="center">

        <Button
            android:id="@+id/speech_widget_25m"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:minHeight="40dp"
            android:text="25m"
            android:textStyle="bold"
            android:textSize="12sp"
            android:textColor="#1a73e8" />

        <Button
            android:id="@+id/speech_widget_resume"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:minHeight="40dp"
            android:text="Resume"
            android:textStyle="bold"
            android:textSize="12sp"
            android:textColor="#1a73e8" />
    </LinearLayout>

    <TextView
        android:id="@+id/speech_widget_open_app"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Open App"
        android:textStyle="bold"
        android:textSize="12sp"
        android:textColor="#1a73e8" />

</LinearLayout>
