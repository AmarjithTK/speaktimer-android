<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_bg"
    android:padding="16dp">

    <!-- Header: app label + tonal "Open" action -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="14dp">

        <!-- M3 Label Small — onSurfaceVariant, wide letter-spacing -->
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Lifer · Timer"
            android:textColor="#FFCAC4D0"
            android:textSize="11sp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.1" />

        <!-- M3 Tonal Button (SecondaryContainer) -->
        <Button
            android:id="@+id/btn_open_app"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="Open"
            android:textAllCaps="false"
            android:textSize="12sp"
            android:fontFamily="sans-serif-medium"
            android:textColor="#FFE8DEF8"
            android:background="@drawable/widget_button_tonal_bg"
            android:paddingStart="16dp"
            android:paddingEnd="16dp" />
    </LinearLayout>

    <!-- Timer value — M3 Display Small, primary color -->
    <TextView
        android:id="@+id/widget_timer_value"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="00:00"
        android:textColor="#FFD0BCFF"
        android:textSize="36sp"
        android:fontFamily="sans-serif-light"
        android:layout_marginBottom="16dp" />

    <!-- Row 1: 5 m · 10 m · 15 m · 20 m · 25 m -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:layout_marginBottom="6dp">

        <Button
            android:id="@+id/btn_5m"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="5dp"
            android:text="5m"
            android:textSize="12sp"
            android:fontFamily="sans-serif-medium"
            android:textColor="#FFE6E1E5"
            android:textAllCaps="false"
            android:background="@drawable/widget_button_bg" />

        <Button
            android:id="@+id/btn_10m"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="5dp"
            android:text="10m"
            android:textSize="12sp"
            android:fontFamily="sans-serif-medium"
            android:textColor="#FFE6E1E5"
            android:textAllCaps="false"
            android:background="@drawable/widget_button_bg" />

        <Button
            android:id="@+id/btn_15m"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="5dp"
            android:text="15m"
            android:textSize="12sp"
            android:fontFamily="sans-serif-medium"
            android:textColor="#FFE6E1E5"
            android:textAllCaps="false"
            android:background="@drawable/widget_button_bg" />

        <Button
            android:id="@+id/btn_20m"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="5dp"
            android:text="20m"
            android:textSize="12sp"
            android:fontFamily="sans-serif-medium"
            android:textColor="#FFE6E1E5"
            android:textAllCaps="false"
            android:background="@drawable/widget_button_bg" />

        <!-- Active preset highlighted with PrimaryContainer -->
        <Button
            android:id="@+id/btn_25m"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="25m"
            android:textSize="12sp"
            android:fontFamily="sans-serif-medium"
            android:textColor="#FFEADDFF"
            android:textAllCaps="false"
            android:background="@drawable/widget_button_active_bg" />
    </LinearLayout>

    <!-- Row 2: 30 m · 45 m · 60 m · 90 m · 120 m -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btn_30m"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="5dp"
            android:text="30m"
            android:textSize="12sp"
            android:fontFamily="sans-serif-medium"
            android:textColor="#FFE6E1E5"
            android:textAllCaps="false"
            android:background="@drawable/widget_button_bg" />

        <Button
            android:id="@+id/btn_45m"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="5dp"
            android:text="45m"
            android:textSize="12sp"
            android:fontFamily="sans-serif-medium"
            android:textColor="#FFE6E1E5"
            android:textAllCaps="false"
            android:background="@drawable/widget_button_bg" />

        <Button
            android:id="@+id/btn_60m"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="5dp"
            android:text="60m"
            android:textSize="12sp"
            android:fontFamily="sans-serif-medium"
            android:textColor="#FFE6E1E5"
            android:textAllCaps="false"
            android:background="@drawable/widget_button_bg" />

        <Button
            android:id="@+id/btn_90m"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="5dp"
            android:text="90m"
            android:textSize="12sp"
            android:fontFamily="sans-serif-medium"
            android:textColor="#FFE6E1E5"
            android:textAllCaps="false"
            android:background="@drawable/widget_button_bg" />

        <Button
            android:id="@+id/btn_120m"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="120m"
            android:textSize="12sp"
            android:fontFamily="sans-serif-medium"
            android:textColor="#FFE6E1E5"
            android:textAllCaps="false"
            android:background="@drawable/widget_button_bg" />
    </LinearLayout>

</LinearLayout>

