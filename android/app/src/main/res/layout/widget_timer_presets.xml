<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_bg"
    android:padding="14dp">

    <!-- Header row: Timer display + Open App button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1.6"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/widget_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="L I F E R"
                android:textColor="#80FFFFFF"
                android:textSize="9sp"
                android:textStyle="bold"
                android:letterSpacing="0.2" />

            <TextView
                android:id="@+id/widget_timer_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00"
                android:textColor="#FFFFFFFF"
                android:textSize="26sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <Button
            android:id="@+id/btn_open_app"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="Open App"
            android:textAllCaps="false"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#E6FFFFFF"
            android:background="@drawable/widget_button_bg"
            android:paddingStart="14dp"
            android:paddingEnd="14dp" />
    </LinearLayout>

    <Space
        android:layout_width="match_parent"
        android:layout_height="12dp" />

    <!-- Row 1: 5 min, 10 min, 15 min, 20 min, 25 min -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:layout_marginBottom="6dp">

        <Button
            android:id="@+id/btn_5m"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="5m"
            android:textSize="12sp"
            android:textColor="#D9FFFFFF"
            android:textAllCaps="false"
            android:background="@drawable/widget_button_bg" />

        <Button
            android:id="@+id/btn_10m"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="10m"
            android:textSize="12sp"
            android:textColor="#D9FFFFFF"
            android:textAllCaps="false"
            android:background="@drawable/widget_button_bg" />

        <Button
            android:id="@+id/btn_15m"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="15m"
            android:textSize="12sp"
            android:textColor="#D9FFFFFF"
            android:textAllCaps="false"
            android:background="@drawable/widget_button_bg" />

        <Button
            android:id="@+id/btn_20m"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="20m"
            android:textSize="12sp"
            android:textColor="#D9FFFFFF"
            android:textAllCaps="false"
            android:background="@drawable/widget_button_bg" />

        <Button
            android:id="@+id/btn_25m"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="25m"
            android:textSize="12sp"
            android:textColor="#FFFFFFFF"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:background="@drawable/widget_button_active_bg" />
    </LinearLayout>

    <!-- Row 2: 30 min, 45 min, 60 min, 90 min, 120 min -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btn_30m"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="30m"
            android:textSize="12sp"
            android:textColor="#D9FFFFFF"
            android:textAllCaps="false"
            android:background="@drawable/widget_button_bg" />

        <Button
            android:id="@+id/btn_45m"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="45m"
            android:textSize="12sp"
            android:textColor="#D9FFFFFF"
            android:textAllCaps="false"
            android:background="@drawable/widget_button_bg" />

        <Button
            android:id="@+id/btn_60m"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="60m"
            android:textSize="12sp"
            android:textColor="#D9FFFFFF"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:background="@drawable/widget_button_bg" />

        <Button
            android:id="@+id/btn_90m"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="90m"
            android:textSize="12sp"
            android:textColor="#D9FFFFFF"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:background="@drawable/widget_button_bg" />

        <Button
            android:id="@+id/btn_120m"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="120m"
            android:textSize="11sp"
            android:textColor="#D9FFFFFF"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:background="@drawable/widget_button_bg" />
    </LinearLayout>

</LinearLayout>
